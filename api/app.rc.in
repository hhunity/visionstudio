VS_VERSION_INFO VERSIONINFO
FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          0x40004L
FILETYPE        0x1L
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "@VS_COMPANY_NAME@"
            VALUE "FileDescription",  "VisionStudio - TIFF Image Viewer"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "visionstudio"
            VALUE "LegalCopyright",   "Copyright (C) @VS_COPYRIGHT_YEAR@ @VS_COMPANY_NAME@"
            VALUE "OriginalFilename", "visionstudio.exe"
            VALUE "ProductName",      "VisionStudio"
            VALUE "ProductVersion",   "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
